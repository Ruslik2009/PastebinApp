<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Кнопки -->

    <Style Selector="Button">
        <Setter Property="Background" Value="#1565C0"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Margin" Value="0 30 10 15"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    

    <!-- TextBox-->
    
    <Style Selector="TextBox">
        <Setter Property="Background" Value="#2D2D30"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="#3E3E42"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="Height" Value="40"/>
    </Style>


    <!-- Cсылка-->

    <Style Selector="TextBlock.tbLink">
        <Setter Property="Foreground" Value="#1565C0"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="TextDecorations" Value="Underline"/>
    </Style>
        

    <!-- Заголовок-->

    <Style Selector="TextBlock.tbTitleText">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,0,30"/>
    </Style>


    <!-- Иконки-->
    
   <Style Selector="PathIcon">
        <Setter Property="Height" Value="20"/>
        <Setter Property="Width" Value="20"/>        
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>


    <!-- Menu-->
    <Style Selector="ListBoxItem">
        <Setter Property="Background" Value="#1976d2" />         
        <Setter Property="Foreground" Value="Black" />
    </Style>
        
    
    <Style Selector="ListBoxItem:focus">
        <Setter Property="Background" Value="#ffffffff" /> <!-- Light Gray Background -->
    </Style>

    <Style Selector="ListBoxItem:selected">
        <Setter Property="Background" Value="#ffffffff" /> <!-- Blue Background -->
        <Setter Property="Foreground" Value="White" />
    </Style>

</Styles>