<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PastebinApp"
             x:Class="PastebinApp.PostsView">

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>    <!-- список постов-->
            <RowDefinition Height="Auto"/> <!-- кнопки -->
        </Grid.RowDefinitions>

        <ListBox x:Name="PostsList" Grid.Row="0"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 Background="#2D2D30">


            <!-- Переопределяем стили ListBoxItem -->
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
                <Style Selector="ListBoxItem:selected">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="ListBoxItem:focus">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ListBox.Styles>

            <!-- список постов-->
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="local:PostDisplay">
                    <Border Background="#252526" 
                            Margin="0,0,0,5" 
                            Padding="20" 
                            CornerRadius="10"
                            BorderBrush="#3E3E40"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="{Binding Username}" 
                                       FontWeight="Bold" 
                                       Foreground="#FFFFFF"
                                       FontSize="15"/>
                            <TextBlock Text="{Binding Content}" 
                                       Margin="0,10,0,0" 
                                       Foreground="#E0E0E0"
                                       FontSize="14"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Created}" 
                                       Margin="0,10,0,0"
                                       Foreground="#A0A0A0"
                                       FontSize="13"/>

                            <!-- reactions -->
                            <StackPanel  Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,1,0,0">
                            
                                <!-- Кнопка лайка со счётчиком внутри -->
                                <Button Padding="10,5" 
                                        CornerRadius="15"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="LikeButton_Click"
                                        Cursor="Hand"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource like}" 
                                                  Width="20" Height="20" 
                                                  Margin="0,0,5,0"
                                                  Foreground="{Binding UserReaction, Converter={StaticResource ReactionColorConverter}, ConverterParameter=1}"/>
                                        <TextBlock Text="{Binding LikesCount}" 
                                                   FontSize="12" 
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding UserReaction, Converter={StaticResource ReactionColorConverter}, ConverterParameter=1}"/>
                                    </StackPanel>
                                </Button>
                            
                                <!-- Кнопка дизлайка со счётчиком внутри -->
                                <Button Padding="10,5" 
                                        CornerRadius="15"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="DislikeButton_Click"
                                        Cursor="Hand"
                                        VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <PathIcon Data="{StaticResource dislike}" 
                                                  Width="20" Height="20" 
                                                  Margin="0,0,5,0"
                                                  Foreground="{Binding UserReaction, Converter={StaticResource ReactionColorConverter}, ConverterParameter=2}"/>
                                        <TextBlock Text="{Binding DislikesCount}" 
                                                   FontSize="12" 
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding UserReaction, Converter={StaticResource ReactionColorConverter}, ConverterParameter=2}"/>
                                    </StackPanel>
                                </Button>
                            
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"  HorizontalAlignment="Right">

            <TextBox x:Name = "UrlTextBox"
                     Watermark = "Enter url"
                     AcceptsReturn = "False"
                     HorizontalAlignment = "Left"
                     Margin = "10,10,10,10"
                     Width = "530"/>


            <Button Content="Search Post"
                    HorizontalAlignment="Right"
                    Click="SearchPost_Click"
                    Margin = "10,10,10,10"
                    CornerRadius="6"/>

            <Button Content="New Post"
                    HorizontalAlignment="Right"
                    Click="CreatePost_Click"
                    Margin = "10,10,10,10"
                    CornerRadius="6"/>

        </StackPanel>

    </Grid>
</UserControl>